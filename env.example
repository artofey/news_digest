# ── Google Sheets (основной режим) ───────────────────
# Опубликованный CSV из Google Sheets — список каналов и тем.
# File → Share → Publish to web → Comma-separated values (.csv)
# Схема колонок: docs/google-sheets-schema.md
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vQ.../pub?output=csv

# ── LLM ──────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Альтернатива Anthropic (опционально):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Рекомендуется для бесплатного режима: только заголовки без AI
USE_LLM=false

# ── Telegram ─────────────────────────────────────────
# Один бот для всех каналов — добавь его админом в каждый канал
# с правом публиковать сообщения. channel_id берётся из Google Sheets.
#
# Шаг 1: Создай бота через @BotFather → получишь токен
TELEGRAM_BOT_TOKEN=1234567890:AAF...

# TELEGRAM_CHAT_ID нужен только для локального fallback (без GOOGLE_SHEET_CSV_URL):
# напиши боту /start, затем открой:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# Найди "chat": {"id": XXXXXXX} — это chat_id
# TELEGRAM_CHAT_ID=123456789
