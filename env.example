# ── LLM ──────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Альтернатива Anthropic (опционально):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Отключить AI и слать только заголовки: USE_LLM=false

# ── Telegram ─────────────────────────────────────────
# Шаг 1: Создай бота через @BotFather → получишь токен
TELEGRAM_BOT_TOKEN=1234567890:AAF...

# Шаг 2: Напиши боту /start, затем открой:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# Найди "chat": {"id": XXXXXXX} — это твой chat_id
TELEGRAM_CHAT_ID=123456789
